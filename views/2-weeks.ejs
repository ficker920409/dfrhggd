<%- include('partials/header') %>

<div class="container">
    <div class="page-title">
        <h1>Weather in <%= city %> - 2 Weeks</h1>
    </div>

    <section class="forecast-widget">
        <table class="forecast-table">
            <thead>
                <tr>
                    <th rowspan="2">Parameter</th>
                    <% dailyForecast.forEach(day => { %>
                        <th class="day-header">
                            <%= day.dayName %>
                            <span class="day-date"><%= day.dateStr %></span>
                        </th>
                    <% }) %>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="row-header">Icon</td>
                    <% dailyForecast.forEach(day => { %>
                        <td class="weather-icon-cell">
                            <img src="/images/weather-icons/<%= day.code %>.svg" alt="<%= day.condition %>" onerror="this.src='/images/weather-icons/default.svg'">
                        </td>
                    <% }) %>
                </tr>
                <tr>
                    <td class="row-header">Temp (Day)</td>
                    <% dailyForecast.forEach(day => { %>
                        <td class="temp-cell <%= day.tempMax > 0 ? 'temp-positive' : 'temp-negative' %>">
                            <%= day.tempMax > 0 ? '+' : '' %><%= day.tempMax %>°
                        </td>
                    <% }) %>
                </tr>
                <tr>
                    <td class="row-header">Temp (Night)</td>
                    <% dailyForecast.forEach(day => { %>
                        <td class="<%= day.tempMin > 0 ? 'temp-positive' : 'temp-negative' %>">
                            <%= day.tempMin > 0 ? '+' : '' %><%= day.tempMin %>°
                        </td>
                    <% }) %>
                </tr>
                <tr>
                    <td class="row-header">Precipitation</td>
                    <% dailyForecast.forEach(day => { %>
                        <td class="precip-cell"><%= day.precipitation %>%</td>
                    <% }) %>
                </tr>
                <tr>
                    <td class="row-header">Wind</td>
                    <% dailyForecast.forEach(day => { %>
                        <td class="wind-cell"><%= day.wind %> m/s<br><%= day.windDir %></td>
                    <% }) %>
                </tr>
                <tr>
                    <td class="row-header">Humidity</td>
                    <% dailyForecast.forEach(day => { %>
                        <td class="humidity-cell"><%= day.humidity %>%</td>
                    <% }) %>
                </tr>
                <tr>
                    <td class="row-header">Pressure</td>
                    <% dailyForecast.forEach(day => { %>
                        <td class="pressure-cell"><%= day.pressure %></td>
                    <% }) %>
                </tr>
            </tbody>
        </table>
    </section>
</div>

<%- include('partials/footer') %>
