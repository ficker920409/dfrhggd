<%- include('partials/header') %>

<div class="container">
    <div class="page-title">
        <h1>Weather in <%= city %></h1>
    </div>

    <!-- Current Weather Widget -->
    <section class="current-weather-widget">
        <div class="widget-header">
            <h2>Current Weather</h2>
            <div class="current-time"><%= new Date().toLocaleString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></div>
        </div>
        <div class="widget-body">
            <div class="temp-main">
                <div class="temp-value">
                    <span class="temp-number"><%= currentWeather.temp > 0 ? '+' : '' %><%= currentWeather.temp %></span>
                    <span class="temp-unit">°C</span>
                </div>
                <div class="weather-icon">
                    <img src="/images/weather-icons/<%= currentWeather.code %>.svg" alt="<%= currentWeather.condition %>" onerror="this.src='/images/weather-icons/default.svg'">
                </div>
            </div>
            <div class="weather-details">
                <div class="detail-row">
                    <span class="detail-label">Feels like</span>
                    <span class="detail-value"><%= currentWeather.feelsLike > 0 ? '+' : '' %><%= currentWeather.feelsLike %>°C</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Wind</span>
                    <span class="detail-value"><%= currentWeather.wind %> m/s, <%= currentWeather.windDir %></span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Humidity</span>
                    <span class="detail-value"><%= currentWeather.humidity %>%</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Pressure</span>
                    <span class="detail-value"><%= currentWeather.pressure %> hPa</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Visibility</span>
                    <span class="detail-value"><%= currentWeather.visibility %> km</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">UV Index</span>
                    <span class="detail-value"><%= currentWeather.uvIndex %></span>
                </div>
            </div>
        </div>
    </section>

    <!-- Hourly Forecast -->
    <section class="hourly-forecast">
        <h2 class="section-title">Hourly Forecast</h2>
        <div class="hourly-scroll">
            <% hourlyForecast.slice(0, 12).forEach(hour => { %>
                <div class="hourly-item">
                    <div class="hour-time"><%= hour.hour.toString().padStart(2, '0') %>:00</div>
                    <div class="hour-icon">
                        <img src="/images/weather-icons/<%= hour.code %>.svg" alt="<%= hour.condition %>" onerror="this.src='/images/weather-icons/default.svg'">
                    </div>
                    <div class="hour-temp"><%= hour.temp > 0 ? '+' : '' %><%= hour.temp %>°</div>
                    <div class="hour-precip"><%= hour.precipitation %>%</div>
                </div>
            <% }) %>
        </div>
    </section>

    <!-- Daily Forecast -->
    <section class="daily-forecast">
        <h2 class="section-title">7-Day Forecast</h2>
        <div class="forecast-table">
            <% dailyForecast.forEach(day => { %>
                <div class="forecast-row">
                    <div class="day-name"><%= day.dayNameLong %></div>
                    <div class="day-date"><%= day.dateStr %></div>
                    <div class="day-icon">
                        <img src="/images/weather-icons/<%= day.code %>.svg" alt="<%= day.condition %>" onerror="this.src='/images/weather-icons/default.svg'">
                    </div>
                    <div class="day-temp">
                        <span class="temp-max"><%= day.tempMax > 0 ? '+' : '' %><%= day.tempMax %>°</span>
                        <span class="temp-min"><%= day.tempMin > 0 ? '+' : '' %><%= day.tempMin %>°</span>
                    </div>
                    <div class="day-precip"><%= day.precipitation %>%</div>
                    <div class="day-wind"><%= day.wind %> m/s <%= day.windDir %></div>
                </div>
            <% }) %>
        </div>
    </section>
</div>

<%- include('partials/footer') %>
